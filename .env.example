# Application
APP_MODE=paper
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=replace-with-at-least-32-random-characters
OPERATOR_PASSWORD=change-me-now
OPERATOR_API_TOKEN=
COOKIE_SECURE=false
ALLOW_DEMO_SEED=true

# PostgreSQL is installed and run as a native operating-system service.
# PostgreSQL is mandatory. No SQLite fallback exists.
DATABASE_URL=postgresql+psycopg://cost_momentum:cost_momentum@localhost:5432/cost_momentum
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

# Optional administrative URL for database creation, restore checks and temporary integration-test databases.
# Prefer setting it only for the command that needs it instead of storing an administrator password permanently.
POSTGRES_ADMIN_URL=
TEST_DATABASE_URL=

# Bybit public/read-only integration
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_RECV_WINDOW=5000
BYBIT_READ_ONLY_ACCOUNT=false

# Market universe
# dynamic: discover all active linear USDT perpetuals, then apply liquidity/data filters.
# static: analyse only SYMBOLS.
UNIVERSE_MODE=dynamic
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT
UNIVERSE_MIN_AGE_DAYS=7
UNIVERSE_MIN_TURNOVER_24H=2000000
UNIVERSE_MAX_SPREAD_BPS=30
# 0 means no top-N cap: analyse every contract that passes the filters.
UNIVERSE_MAX_SYMBOLS=0
UNIVERSE_REFRESH_SECONDS=300
UNIVERSE_MIN_HISTORY_BARS=72
UNIVERSE_EXCLUDED_SYMBOLS=
UNIVERSE_EXCLUDED_BASE_COINS=USDC,USDE,FDUSD,TUSD,USDP,BUSD,PYUSD,DAI,EURC,EUR
# Bybit symbolType is a region/segment; only explicit xStocks are blocked by this switch
UNIVERSE_ALLOW_NON_CRYPTO_SYMBOL_TYPES=false
UNIVERSE_BACKFILL_BATCH_SIZE=40
UNIVERSE_SYNC_MARK_PRICE=false
UNIVERSE_ENRICH_FUNDING_OI=false
TICKER_RETENTION_HOURS=48

CANDLE_INTERVAL=60
INITIAL_BACKFILL_BARS=500
MARKET_POLL_SECONDS=60
INSTRUMENT_REFRESH_SECONDS=21600
INFERENCE_DELAY_SECONDS=75

# Strategy and policy defaults
HORIZONS_HOURS=4,8,12
DEFAULT_HORIZON_HOURS=8
DEFAULT_LEVERAGE=3
MAX_LEVERAGE=5
DEFAULT_RISK_RATE=0.0035
MAX_TOTAL_OPEN_RISK_RATE=0.02
MARGIN_RESERVE_RATE=0.25
MIN_NET_RR=1.20
MIN_NET_EV_R=0.05
MAX_SPREAD_BPS=18
MAX_TICKER_AGE_SECONDS=120
MAX_CANDLE_AGE_SECONDS=4200
SIGNAL_TTL_MINUTES=90
FEE_RATE_TAKER=0.00055
BASE_SLIPPAGE_BPS=3
STOP_GAP_RESERVE_BPS=10

# Model
MODEL_DIR=models
ACTIVE_MODEL_PATH=
ALLOW_BASELINE_MODEL=true

# Worker
WORKER_ID=worker-1
HEARTBEAT_SECONDS=15
