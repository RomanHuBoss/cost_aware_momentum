# Application
APP_MODE=paper
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=replace-with-at-least-32-random-characters
OPERATOR_PASSWORD=change-me-now
OPERATOR_API_TOKEN=
COOKIE_SECURE=false
ALLOW_DEMO_SEED=true

# PostgreSQL is installed and run as a native operating-system service.
# PostgreSQL is mandatory. No SQLite fallback exists.
DATABASE_URL=postgresql+psycopg://cost_momentum:cost_momentum@localhost:5432/cost_momentum
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10

# Optional administrative URL for database creation, restore checks and temporary integration-test databases.
# Prefer setting it only for the command that needs it instead of storing an administrator password permanently.
POSTGRES_ADMIN_URL=
TEST_DATABASE_URL=

# Bybit public/read-only integration
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_RECV_WINDOW=5000
BYBIT_READ_ONLY_ACCOUNT=false

# Market universe
# dynamic: discover all active linear USDT perpetuals, then apply liquidity/data filters.
# static: analyse only SYMBOLS.
UNIVERSE_MODE=dynamic
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT
UNIVERSE_MIN_AGE_DAYS=7
UNIVERSE_MIN_TURNOVER_24H=2000000
UNIVERSE_MAX_SPREAD_BPS=30
# 0 means no top-N cap: analyse every contract that passes the filters.
UNIVERSE_MAX_SYMBOLS=0
UNIVERSE_REFRESH_SECONDS=300
UNIVERSE_MIN_HISTORY_BARS=72
UNIVERSE_EXCLUDED_SYMBOLS=
UNIVERSE_EXCLUDED_BASE_COINS=USDC,USDE,FDUSD,TUSD,USDP,BUSD,PYUSD,DAI,EURC,EUR
# Most symbolType values are crypto regions/segments. Known TradFi families
# stock, forex, commodity and xstocks/xstock are excluded unless explicitly enabled.
UNIVERSE_ALLOW_NON_CRYPTO_SYMBOL_TYPES=false
UNIVERSE_BACKFILL_BATCH_SIZE=40
UNIVERSE_SYNC_MARK_PRICE=false
UNIVERSE_ENRICH_FUNDING_OI=false
TICKER_RETENTION_HOURS=48

CANDLE_INTERVAL=60
# Fast startup backfill for newly admitted symbols. Deeper history is filled progressively below.
INITIAL_BACKFILL_BARS=1000
# Progressively extend last-price history without blocking API/inference startup.
HISTORY_BACKFILL_ENABLED=true
HISTORY_BACKFILL_TARGET_DAYS=365
HISTORY_BACKFILL_INTERVAL_SECONDS=60
HISTORY_BACKFILL_SYMBOLS_PER_CYCLE=5
HISTORY_BACKFILL_PAGES_PER_SYMBOL=2
HISTORY_BACKFILL_PAGE_SIZE=1000
MARKET_POLL_SECONDS=60
INSTRUMENT_REFRESH_SECONDS=21600
INFERENCE_DELAY_SECONDS=75
# Resolve hourly TP/SL ambiguity from exact public/read-only intrabar windows.
OUTCOME_INTRABAR_INTERVAL=5
OUTCOME_INTRABAR_MAX_WINDOWS_PER_CYCLE=100

# Strategy and policy defaults
HORIZONS_HOURS=4,8,12
DEFAULT_HORIZON_HOURS=8
DEFAULT_LEVERAGE=3
MAX_LEVERAGE=5
DEFAULT_RISK_RATE=0.0035
MAX_TOTAL_OPEN_RISK_RATE=0.02
MARGIN_RESERVE_RATE=0.25
MIN_NET_RR=1.20
# Must be non-negative; expected-loss plans cannot be made actionable by configuration.
MIN_NET_EV_R=0.05
MAX_SPREAD_BPS=18
MAX_TICKER_AGE_SECONDS=120
# Read-only account equity/margin snapshots older than this block execution plans and accept.
MAX_ACCOUNT_SNAPSHOT_AGE_SECONDS=180
MAX_CANDLE_AGE_SECONDS=4200
SIGNAL_TTL_MINUTES=90
FEE_RATE_TAKER=0.00055
BASE_SLIPPAGE_BPS=3
STOP_GAP_RESERVE_BPS=10
# Baseline/legacy fallback gross return for TIMEOUT before fees/slippage.
# ML artifacts v1.9.0+ persist train-only direction-conditional TIMEOUT estimates instead.
TIMEOUT_GROSS_RETURN_RATE=-0.002

# Model runtime
MODEL_DIR=models
ACTIVE_MODEL_PATH=
ALLOW_BASELINE_MODEL=true
# Diagnostic fallback only. Keep false; production rejects true.
ALLOW_BASELINE_ACTIONABLE=false
# Registry-active artifacts are reloaded by the inference worker without restarting it.
MODEL_REFRESH_SECONDS=300

# Background retraining
# A separate trainer process periodically builds an immutable candidate from confirmed candles.
AUTO_TRAIN_ENABLED=true
# Candidate is activated only after absolute and incumbent-relative quality gates pass.
AUTO_TRAIN_AUTO_ACTIVATE=true
AUTO_TRAIN_MODEL_TYPE=hist_gradient_boosting
# 168 hours = weekly retraining. Use 24 for a daily paper/shadow experiment.
AUTO_TRAIN_INTERVAL_HOURS=168
AUTO_TRAIN_RETRY_HOURS=6
# When no usable trained model exists, retry technical bootstrap/recovery failures quickly.
AUTO_TRAIN_RECOVERY_RETRY_MINUTES=15
AUTO_TRAIN_CHECK_SECONDS=300
AUTO_TRAIN_INITIAL_DELAY_SECONDS=120
AUTO_TRAIN_LOOKBACK_DAYS=365
# Top symbols by latest 24h turnover; 0 uses every stored symbol.
AUTO_TRAIN_MAX_SYMBOLS=100
AUTO_TRAIN_MIN_NEW_TIMESTAMPS=168
# A material historical backfill or universe expansion bypasses the weekly schedule
# after this shorter cooldown. A candidate rejected by the quality gate is not rebuilt
# on an unchanged deterministic dataset after the cooldown; it waits for the same new-data
# threshold or a material profile change.
AUTO_TRAIN_DATA_CHANGE_COOLDOWN_HOURS=6
AUTO_TRAIN_MIN_NEW_ROWS=10000
AUTO_TRAIN_MIN_DATASET_GROWTH_RATIO=0.10
AUTO_TRAIN_MIN_NEW_SYMBOLS=5
AUTO_TRAIN_MIN_UNIVERSE_CHANGE_RATIO=0.10
AUTO_TRAIN_MIN_BARS_PER_SYMBOL=300
AUTO_TRAIN_MIN_SYMBOL_COVERAGE_RATIO=0.80
AUTO_TRAIN_MIN_HOLDOUT_ROWS=180
# Holdout decisions must cover at least one complete 7-day crypto market cycle.
AUTO_TRAIN_MIN_HOLDOUT_SPAN_HOURS=168
AUTO_TRAIN_MIN_CLASS_FRACTION=0.02
AUTO_TRAIN_MAX_LOG_LOSS=1.20
AUTO_TRAIN_MAX_MULTICLASS_BRIER=0.75
AUTO_TRAIN_MAX_ECE=0.15
AUTO_TRAIN_MAX_LOG_LOSS_REGRESSION=0.01
AUTO_TRAIN_MAX_BRIER_REGRESSION=0.01
AUTO_TRAIN_MIN_METRIC_IMPROVEMENT=0.002
# The automatic promotion gate also requires usable holdout economics under the
# same fee/slippage/EV thresholds as live policy. This is not a portfolio backtest,
# but it prevents activation of a statistically neat model with no tradable edge.
AUTO_TRAIN_MIN_POLICY_TRADES=20
# Minimum fraction of evaluated symbol/timestamp candidates that remains tradable
# after live-equivalent economics and one-active-symbol overlap filtering.
AUTO_TRAIN_MIN_POLICY_TRADE_RATE=0.01
# Horizon-separated decision cohorts whose label windows do not overlap.
# With the default 8h horizon, hourly cohorts at t..t+7 count as one independent cohort.
AUTO_TRAIN_MIN_POLICY_COHORTS=20
# With AUTO_TRAIN_AUTO_ACTIVATE=true this value must be >= 0.
AUTO_TRAIN_MIN_POLICY_REALIZED_MEAN_R=0.0
# With AUTO_TRAIN_AUTO_ACTIVATE=true this value must be >= 1.
AUTO_TRAIN_MIN_POLICY_PROFIT_FACTOR=1.0
AUTO_TRAIN_MAX_POLICY_DRAWDOWN_R=30.0
AUTO_TRAIN_MAX_POLICY_MEAN_R_REGRESSION=0.02
AUTO_TRAIN_MAX_POLICY_DRAWDOWN_REGRESSION_R=2.0
AUTO_TRAIN_MIN_POLICY_IMPROVEMENT_R=0.01
AUTO_TRAIN_REQUIRE_IMPROVEMENT=true

# Workers
WORKER_ID=worker-1
TRAINER_ID=trainer-1
HEARTBEAT_SECONDS=15
