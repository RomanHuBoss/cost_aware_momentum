MANIFEST

# Runtime artifacts. Keep only directory placeholders in Git.
models/*
!models/.gitkeep
reports/*
!reports/.gitkeep
backups/*
!backups/.gitkeep
logs/
*.log
*.log.*
*.pid
*.pid.lock
*.sock
nohup.out

# Model, database and backup artifacts written outside standard directories
*.joblib
*.pkl
*.pickle
*.onnx
*.dump
*.backup
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal

# Temporary/editor files
.tmp/
tmp/
temp/
*.tmp
*.temp
*.bak
*.orig
*.rej
*.swp
*.swo
*~

# IDE settings
.idea/
.vscode/
*.iml
*.code-workspace

# Operating-system metadata
.DS_Store
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

